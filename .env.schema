CERTIFICATE_PEM=bitwarden("f3440bb3-5275-47e5-905c-b44200817f79")

# @required @sensitive
PRIVATE_KEY_PEM=bitwarden("2f74b5e6-c5bb-44f7-bdfa-b44200817fd7")
